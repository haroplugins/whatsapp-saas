generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  NEW
  INTERESTED
  QUOTE_SENT
  PENDING
  CLOSED
  LOST
}

enum ConversationControlMode {
  NONE
  AI
  HUMAN
}

enum TenantPlan {
  BASIC
  PRO
  PREMIUM
}

enum MessageSender {
  USER
  CLIENT
}

enum TriggerType {
  KEYWORD
  STATUS_CHANGE
  TIME_DELAY
}

enum ActionType {
  SEND_MESSAGE
  TAG
  CHANGE_STATUS
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentSource {
  MANUAL
  WHATSAPP
  AI
  IMPORT
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  plan            TenantPlan       @default(BASIC)
  users           User[]
  conversations   Conversation[]
  automations     Automation[]
  services        Service[]
  appointments    Appointment[]
  blockedSlots    BlockedSlot[]
  bookingSettings BookingSettings?
  availabilityRules AvailabilityRule[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([tenantId, email])
}

model Conversation {
  id          String                  @id @default(cuid())
  tenantId    String
  phone       String
  name        String?
  status      ConversationStatus
  controlMode ConversationControlMode @default(NONE)
  isBusiness  Boolean
  messages    Message[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  sender         MessageSender
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Automation {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  triggerType  TriggerType
  triggerValue String
  actionType   ActionType
  actionValue  String
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Service {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int?
  currency        String        @default("EUR")
  bufferMinutes   Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([tenantId])
}

model Appointment {
  id            String            @id @default(cuid())
  tenantId      String
  serviceId     String?
  customerName  String
  customerPhone String?
  startAt       DateTime
  endAt         DateTime
  status        AppointmentStatus @default(PENDING)
  source        AppointmentSource @default(MANUAL)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service       Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([serviceId])
  @@index([tenantId, startAt])
}

model BlockedSlot {
  id        String   @id @default(cuid())
  tenantId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, startAt])
}

model BookingSettings {
  id                       String   @id @default(cuid())
  tenantId                 String   @unique
  timezone                 String   @default("Europe/Madrid")
  minNoticeHours           Int      @default(2)
  maxDaysAhead             Int      @default(30)
  requireHumanConfirmation Boolean  @default(true)
  allowAutoConfirm         Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  tenantId  String
  weekday   Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, weekday])
}
