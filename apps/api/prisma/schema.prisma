generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  NEW
  INTERESTED
  QUOTE_SENT
  PENDING
  CLOSED
  LOST
}

enum ConversationControlMode {
  NONE
  AI
  HUMAN
}

enum TenantPlan {
  BASIC
  PRO
  PREMIUM
}

enum MessageSender {
  USER
  CLIENT
  AI
}

enum MessageExternalProvider {
  WHATSAPP_CLOUD_API
}

enum ConversationDraftSource {
  MANUAL
  BOOKING_ADVISOR
}

enum ConversationDraftStatus {
  ACTIVE
  APPLIED
  DISCARDED
}

enum TriggerType {
  KEYWORD
  STATUS_CHANGE
  TIME_DELAY
}

enum ActionType {
  SEND_MESSAGE
  TAG
  CHANGE_STATUS
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentSource {
  MANUAL
  WHATSAPP
  AI
  IMPORT
}

enum SmartBookingMode {
  SUGGEST_SLOTS
  REQUEST_CONFIRMATION
  AUTO_CONFIRM
}

enum SmartBookingMissingInfoBehavior {
  ASK_CLIENT
  HANDOFF_TO_HUMAN
}

enum AutomaticReplySource {
  BOOKING_ADVISOR
  CLASSIC_AUTOMATION
  OFF_HOURS
}

enum AutomaticReplyStatus {
  DRY_RUN
  SENT
  BLOCKED
  FAILED
}

enum MessageDeliveryProvider {
  WHATSAPP_CLOUD_API
}

enum MessageDeliveryDirection {
  OUTBOUND
  INBOUND
}

enum MessageDeliveryStatus {
  DRY_RUN
  BLOCKED
  SENT
  FAILED
}

enum WhatsappConnectionProvider {
  WHATSAPP_CLOUD_API
}

enum WhatsappConnectionStatus {
  ACTIVE
  DISABLED
}

model Tenant {
  id                   String                @id @default(cuid())
  name                 String
  plan                 TenantPlan            @default(BASIC)
  defaultCurrency      String                @default("EUR")
  users                User[]
  conversations        Conversation[]
  automations          Automation[]
  conversationDrafts   ConversationDraft[]
  services             Service[]
  appointments         Appointment[]
  blockedSlots         BlockedSlot[]
  bookingSettings      BookingSettings?
  availabilityRules    AvailabilityRule[]
  smartBookingSettings SmartBookingSettings?
  bookingAgentDryRuns  BookingAgentDryRunLog[] @relation("BookingAgentDryRunTenant")
  automaticReplyLogs   AutomaticReplyLog[]
  messageDeliveryLogs  MessageDeliveryLog[]
  whatsappConnections  TenantWhatsappConnection[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingAgentDryRuns BookingAgentDryRunLog[] @relation("BookingAgentDryRunUser")
  conversationDrafts ConversationDraft[] @relation("ConversationDraftUser")

  @@index([tenantId])
  @@unique([tenantId, email])
}

model Conversation {
  id          String                  @id @default(cuid())
  tenantId    String
  phone       String
  name        String?
  status      ConversationStatus
  controlMode ConversationControlMode @default(NONE)
  isBusiness  Boolean
  messages    Message[]
  draft       ConversationDraft?
  automaticReplyLogs AutomaticReplyLog[]
  messageDeliveryLogs MessageDeliveryLog[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Message {
  id                String                   @id @default(cuid())
  conversationId    String
  sender            MessageSender
  content           String
  externalProvider  MessageExternalProvider?
  externalMessageId String?
  createdAt         DateTime                 @default(now())
  conversation      Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  automaticReplyTriggerLogs AutomaticReplyLog[] @relation("AutomaticReplyTriggeringMessage")
  automaticReplySentLogs AutomaticReplyLog[] @relation("AutomaticReplySentMessage")
  deliveryLogs   MessageDeliveryLog[]

  @@index([conversationId])
  @@unique([externalProvider, externalMessageId])
  @@index([externalProvider, externalMessageId])
}

/// Draft text prepared for a conversation. Not a sent message.
/// Before production use, apply retention/privacy policy.
model ConversationDraft {
  id             String                  @id @default(cuid())
  tenantId       String
  conversationId String                  @unique
  userId         String?
  content        String
  source         ConversationDraftSource @default(MANUAL)
  status         ConversationDraftStatus @default(ACTIVE)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?                   @relation("ConversationDraftUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, updatedAt])
  @@index([tenantId, source])
  @@index([tenantId, status])
  @@index([userId])
}

model Automation {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  triggerType  TriggerType
  triggerValue String
  actionType   ActionType
  actionValue  String
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Service {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int?
  currency        String        @default("EUR")
  bufferMinutes   Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([tenantId])
}

model Appointment {
  id            String            @id @default(cuid())
  tenantId      String
  serviceId     String?
  customerName  String
  customerPhone String?
  startAt       DateTime
  endAt         DateTime
  status        AppointmentStatus @default(PENDING)
  source        AppointmentSource @default(MANUAL)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service       Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([serviceId])
  @@index([tenantId, startAt])
}

model BlockedSlot {
  id        String   @id @default(cuid())
  tenantId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, startAt])
}

model BookingSettings {
  id                       String   @id @default(cuid())
  tenantId                 String   @unique
  timezone                 String   @default("Europe/Madrid")
  minNoticeHours           Int      @default(2)
  maxDaysAhead             Int      @default(30)
  requireHumanConfirmation Boolean  @default(true)
  allowAutoConfirm         Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  tenantId  String
  weekday   Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, weekday])
}

model SmartBookingSettings {
  id                  String                          @id @default(cuid())
  tenantId            String                          @unique
  enabled             Boolean                         @default(false)
  mode                SmartBookingMode                @default(SUGGEST_SLOTS)
  maxSuggestions      Int                             @default(3)
  missingInfoBehavior SmartBookingMissingInfoBehavior @default(ASK_CLIENT)
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  tenant              Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Dry-run audit log for booking orchestrator decisions.
/// Contains customer-provided text in inputText/resultJson.
/// Before production use, apply retention and encryption/privacy policy.
model BookingAgentDryRunLog {
  id                     String   @id @default(cuid())
  tenantId               String
  userId                 String?
  inputText              String
  intent                 String?
  decision               String?
  nextAction             String?
  suggestedReplyPrepared Boolean
  suggestedReplyReason   String?
  suggestedReplyText     String?
  hasAvailability        Boolean?
  availabilityChecked    Boolean
  serviceName            String?
  serviceId              String?
  date                   String?
  timePreference         String?
  resultJson             Json
  createdAt              DateTime @default(now())
  tenant                 Tenant   @relation("BookingAgentDryRunTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  user                   User?    @relation("BookingAgentDryRunUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, decision])
  @@index([tenantId, intent])
  @@index([userId])
}

model AutomaticReplyLog {
  id                  String                @id @default(cuid())
  tenantId            String
  conversationId      String
  triggeringMessageId String
  sentMessageId       String?
  source              AutomaticReplySource?
  routerDecision      String
  selectedSource      String?
  status              AutomaticReplyStatus @default(DRY_RUN)
  reason              String?
  replyTextPreview    String?
  replyTextHash       String?
  resultJson          Json?
  expiresAt           DateTime?
  createdAt           DateTime              @default(now())
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation        Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  triggeringMessage   Message               @relation("AutomaticReplyTriggeringMessage", fields: [triggeringMessageId], references: [id], onDelete: Cascade)
  sentMessage         Message?              @relation("AutomaticReplySentMessage", fields: [sentMessageId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([conversationId])
  @@index([triggeringMessageId])
}

model MessageDeliveryLog {
  id                String                   @id @default(cuid())
  tenantId          String
  conversationId    String
  messageId         String
  provider          MessageDeliveryProvider
  direction         MessageDeliveryDirection @default(OUTBOUND)
  status            MessageDeliveryStatus
  externalMessageId String?
  phoneNumberId     String?
  recipientHash     String?
  httpStatus        Int?
  errorCode         String?
  errorType         String?
  errorMessage      String?
  resultJson        Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  expiresAt         DateTime?
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message           Message                  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, provider])
  @@index([tenantId, messageId, status])
  @@index([conversationId])
  @@index([messageId])
  @@index([externalMessageId])
  @@index([expiresAt])
}

model TenantWhatsappConnection {
  id                 String                     @id @default(cuid())
  tenantId           String
  provider           WhatsappConnectionProvider @default(WHATSAPP_CLOUD_API)
  phoneNumberId      String
  displayPhoneNumber String?
  businessAccountId  String?
  status             WhatsappConnectionStatus   @default(ACTIVE)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([provider, phoneNumberId])
  @@index([tenantId])
  @@index([tenantId, status])
}
